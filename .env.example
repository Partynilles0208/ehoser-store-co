# Kopiere diese Datei zu .env und fülle die Werte ein

# === BEIDE OPTIONEN ===
PORT=3000
NODE_ENV=development
JWT_SECRET=dein-super-sicherer-secret-key-min-20-zeichen
ADMIN_UPLOAD_KEY=Nils2014!

# === OPTION 1: SQLite (Lokal Development) ===
# Benutze: npm start
# (Keine extra Variablen nötig)

# === OPTION 2: Supabase (Production) ===
# Benutze: npm run start:supabase

# Kopiere diese von Supabase Dashboard → Project Settings:
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
GROQ_API_KEY=
OPENAI_API_KEY=
PREMIUM_OPENAI_MODEL=gpt-5-mini

# === Eigenes Email Center / eigener Mailserver ===
MAIL_DOMAIN=ehoser.de
MAIL_INBOUND_SECRET=ein-sehr-langes-geheimes-passwort
MAIL_INBOUND_URL=http://127.0.0.1:3000/api/mail/inbound
MAIL_SENDMAIL_PATH=/usr/sbin/sendmail

# DATABASE_URL: Project Settings → Database → Connection String (Transaction mode)
DATABASE_URL=postgresql://postgres.your_project:[PASSWORD]@db.your_project.supabase.co:6543/postgres

# === PRODUCTION (Railway) ===
# Setze diese Variablen im Railway Dashboard, NICHT hier!
# Alle oben genannten Variablen gehören ins Railway Dashboard
